val S = require "atmos.streams"

require "atmos.env.sdl"
require "game"
require "radar"

spawn {
    every :sdl.step {
        ;;print "-=-=-"
    }
}

val devs = #{
    "/dev/ttyACM0",
    "/dev/ttyACM1",
    "/dev/ttyACM2",
}

pin radars = tasks()

par {
    every _,v,dev in :radar.on {
        xprint(dev,v)
    }
} with {
    every _,err in :radar.err {
        xprint(err)
    }
} with {
    every @1 {
        val ons = S.from(#{} ++ radars)::map \{it.pub.dev}::table()::to() || #{}
        loop _,dev in devs {
            if dev !> ons {
                catch true {
                    spawn [radars] Radar(dev)
                }
            }
        }
    }
} with {
    every v in :radar.raw {
        xprint(v)
    }
}
