require "atmos.env.sdl"
require "game"
require "radar"

;;;
- radar.pos (posicionado atras do jog a :l/:r do juiz)
- radar.hand (:l, :r)
;;;

;;spawn Probe(@1)
pin r = spawn Radar("/dev/ttyACM0")
set r.pub.pos = :l

every v in :radar {
    xprint(v)
}

;;;
spawn Shots()
every v in :out.shot {
    xprint(v)
}
