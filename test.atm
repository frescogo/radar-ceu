require "atmos.env.clock"
require "regra"

spawn {
    await(:go.game, true)
    await(:go.phase, true, :speed)

    await(:go.seq, true, 0)
    val _,s = await(:go.shot)
    assert((s.now==0) && (s.dir==:in) && (s.vel==40))
    val _,s = await(:go.shot)
    assert((s.now==500) && (s.dir==:out) && (s.vel==60))
    await(:go.fall, 0)
    await(:go.seq, false, 0)

    await(:go.seq, true, 1)
    val _,s = await(:go.shot)
    assert((s.now==0) && (s.dir==:in) && (s.vel==34))
    await(:go.seq, false, 1)

    await(:go.phase, false, :speed)
    await(:go.phase, true, :power)

    print :ok
}

pin jogo = spawn Game()

emit(:shot @{dir=:out,vel=31})
emit('sdl.step', 100000)
emit(:shot @{dir=:in,vel=34})
emit('sdl.step', 100)
assert(jogo.pub.time == 0)

emit :serve
emit('sdl.step', 500)
emit(:shot @{dir=:in,vel=40})
assert(jogo.pub.time == 0)
emit('sdl.step', 500)
emit(:shot @{dir=:out,vel=60})
emit('sdl.step', 500)
assert(jogo.pub.time == 1000)
emit :fall

emit(:shot @{dir=:out,vel=31})
emit('sdl.step', 100000)
emit(:shot @{dir=:in,vel=34})
emit('sdl.step', 100)
assert(jogo.pub.time == 1000)

emit :serve
emit(:shot @{dir=:in,vel=34})
emit('sdl.step', (6*60*1000)/2)
emit :fall
print :ok
