require "atmos.env.clock"
require "regra"

pin jogo = spawn Game()

spawn {
}

emit(:shot @{dir=:out,vel=31})
emit('sdl.step', 100000)
emit(:shot @{dir=:in,vel=34})
emit('sdl.step', 100)
assert(jogo.pub.time == 0)

emit :serve
emit('sdl.step', 500)
emit(:shot @{dir=:in,vel=40})
assert(jogo.pub.time == 0)
assert (
    (jogo.pub.phase == :speed) &&
    (#jogo.pub.seqs.speed == 1) &&
    (jogo.pub.seqs.speed[0] --> \{
        (#it == 1) && (it[0] --> \{
            (it.now==0) && (it.dir==:in) && (it.vel==40)
        })
    })
)
emit('sdl.step', 500)
emit(:shot @{dir=:out,vel=60})
emit('sdl.step', 500)
assert(jogo.pub.time == 1000)
emit :fall
assert (
    (#jogo.pub.seqs.speed == 1) &&
    (jogo.pub.seqs.speed[0] --> \{
        (#it == 2) && (it[1] --> \{
            (it.now==500) && (it.dir==:out) && (it.vel==60)
        })
    })
)

emit(:shot @{dir=:out,vel=31})
emit('sdl.step', 100000)
emit(:shot @{dir=:in,vel=34})
emit('sdl.step', 100)
assert(jogo.pub.time == 1000)

emit :serve
emit(:shot @{dir=:in,vel=34})
emit('sdl.step', (6*60*1000)/2)
emit :fall
print :ok
