require "atmos.env.clock"
require "regra"

spawn {
    ;; GAME 1
    print("GAME 1: ??")
    do {
        await(:go.game, true)
        await(:go.phase, true, :speed)

        await(:go.seq, true, 0)
        val _,s = await(:go.shot)
        assert((s.now==0) && (s.dir==:in) && (s.vel==40))
        val _,s = await(:go.shot)
        assert((s.now==500) && (s.dir==:out) && (s.vel==60))
        await(:go.fall, 0)
        await(:go.seq, false, 0)

        await(:go.seq, true, 1)
        val _,s = await(:go.shot)
        assert((s.now==0) && (s.dir==:in) && (s.vel==34))
        await(:go.seq, false, 1)

        await(:go.phase, false, :speed)
        await(:go.phase, true, :power)

        await(:go.seq, true, 0)
        loop i in 4 {
            val _,so = await(:go.shot)
            assert((so.now==(i*500)) && (so.dir==:out) && (so.vel==50))
            val _,si = await(:go.shot)
            assert((si.now==((i*500) + 250)) && (si.dir==:in) && (si.vel==50))
        }
        await(:go.seq, false, 0)

        await(:go.phase, false, :power)
        await(:go.game, false)
    }
    print("GAME 1: ok")

    print("GAME 2: ??")
    do {
    }
    print("GAME 2: ok")
}

pin j1 = spawn Game()
watching j1 {
    emit(:shot @{dir=:out,vel=31})
    emit('sdl.step', 100000)
    emit(:shot @{dir=:in,vel=34})
    emit('sdl.step', 100)
    assert(j1.pub.time == 0)

    ;; SPEED

    ;; SEQ 0
    emit :serve
    emit('sdl.step', 500)
    emit(:shot @{dir=:in,vel=40})
    assert(j1.pub.time == 0)
    emit('sdl.step', 500)
    emit(:shot @{dir=:out,vel=60})
    emit('sdl.step', 500)
    assert(j1.pub.time == 1000)
    emit :fall

    emit(:shot @{dir=:out,vel=31})
    emit('sdl.step', 100000)
    emit(:shot @{dir=:in,vel=34})
    emit('sdl.step', 100)
    assert(j1.pub.time == 1000)

    ;; SEQ 1
    emit :serve
    emit(:shot @{dir=:in,vel=34})
    emit('sdl.step', (6*60*1000)/2)
    emit :fall

    ;; POWER

    ;; SEQ 0
    emit :serve
    loop _ in 4 {
        emit(:shot @{dir=:out,vel=50})
        emit('sdl.step', 250)
        emit(:shot @{dir=:in,vel=50})
        emit('sdl.step', 250)
    }
    emit('sdl.step', (6*60*1000)/2)
}

print :ok
