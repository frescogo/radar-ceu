require "atmos.env.clock"
require "game"

func seq (t) {
    var now = t[0][0]
    emit :out.serve
    loop _,v in t {
        val dt = v[0] - now
        set now = v[0]
        emit(:sdl.step, dt)
        emit(:out.shot @{jog=v[1],vel=v[2]})
    }
}

pin j = spawn Game()
;;;
spawn Points()
spawn {
    every _,pts in :go.pts.speed {
        xprint(pts)
    }
}
;;;

