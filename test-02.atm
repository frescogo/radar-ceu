require "atmos.env.clock"
require "regra"

spawn {
    print("GAME 2: ??")
    do {
        await(:go.game, true)
        await(:go.phase, true, :speed)

        ;; SEQ 0
        do {
            await(:go.seq, true, 0)
            loop i in 63 {
                val _,s = await(:go.shot)
                if i ?> #{9,10,14,18,19,20,22,23,24,28,41,42} {
                    assert(s.valid)
                } else {
                    assert(!s.valid)
                }
            }
            val _,_,t = await(:go.fall, 0)
            assert(t == 49252)
            await(:go.seq, false, 0)
        }

        ;; SEQ 1
        do {
            await(:go.seq, true, 1)
            loop i in 43 {
                val _,s = await(:go.shot)
                if i ?> #{10,11,15,33,38,42} {
                    assert(s.valid)
                } else {
                    assert(!s.valid)
                }
            }
            val _,_,t = await(:go.fall, 1)
            assert(t == 86669)
            await(:go.seq, false, 1)
        }

        ;; SEQ 2
        do {
            await(:go.seq, true, 2)
            loop i in 43 {
                val _,s = await(:go.shot)
                if i ?> #{10,11,13,26,47,48,54,55,69,74,75,76,83,84,86,87,89,90,102,103,111,112,113,114,117,118} {
                    assert(s.valid)
                } else {
                    assert(!s.valid)
                }
            }
            watching :go.seq, false, 2 {
                await(:go.fall, 2)
                error()
            }
        }
    }
    print("GAME 2: ok")
}

func seq (t) {
    var now = t[0][0]
    emit :serve
    loop _,v in t {
        val dt = v[0] - now
        set now = v[0]
        emit('sdl.step', dt)
        emit(:shot @{dir=v[1],vel=v[2]})
    }
}

